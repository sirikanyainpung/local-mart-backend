generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BrandMaster {
  brand_id    Int          @id @default(autoincrement())
  brand_code  String       @db.VarChar(250)
  brand_name  String       @db.VarChar(250)
  status      String?      @db.VarChar(50)

  brand_models BrandModel[]

  @@map("brand_masters")
}

model BrandModel {
  brand_model_id   Int     @id @default(autoincrement())
  brand_id         Int
  brand_model_code String  @db.VarChar(250)
  brand_model_name String  @db.VarChar(250)
  status           String? @db.VarChar(50)

  brand BrandMaster @relation(fields: [brand_id], references: [brand_id])

  @@map("brand_model")
}

model ProductMaster {
  product_id        Int              @id @default(autoincrement())
  sku_code          String
  product_name      String
  product_description String?
  category_id       Int
  brand_id          Int
  brand_model_id    Int
  status            String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  barcodes ProductBarcode[]
  images   ProductImage[]

  @@map("product_masters")
}

model ProductBarcode {
  barcode_id Int @id @default(autoincrement())
  barcode    String
  product_id Int
  unit_id    Int
  qty        Int
  vat        String
  cost_price Float
  sale_price Float

  status String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product ProductMaster @relation(fields: [product_id], references: [product_id])

  @@map("product_barcode")
}

model ProductImage {
  image_id   Int    @id @default(autoincrement())
  product_id Int
  sku_code   String
  image_type String
  image_index   Int
  image_path String

  status String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product ProductMaster @relation(fields: [product_id], references: [product_id])

  @@map("product_images")
}

model UnitMaster {
  unit_id    Int     @id @default(autoincrement())
  unit_code  String
  unit_name  String
  unit_qty   Int
  category_id Int
  status     String?

  @@map("unit_master")
}